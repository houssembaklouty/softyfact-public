APP_NAME=SoftyFact
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://softyfact.tn

CORE_APP_URL=https://app.softyfact.tn

DB_CONNECTION=sqlite
DB_DATABASE=/var/www/softyfact-public/storage/app/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=softyfact_public_session

CACHE_STORE=file
LOG_CHANNEL=stack

APP_SUPPORT_PHONE="71 000 000"
APP_ORDER_AMOUNT=119
APP_ORDER_AMOUNT_ONLINE=119

PUBLIC_SITE_API_KEY=

# Admin notifications (leave empty to disable)
ADMIN_EMAIL=

# Mail (SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@softyfact.tn
MAIL_FROM_NAME=SoftyFact
